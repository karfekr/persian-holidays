{
	"name": "persian-holidays",
	"version": "0.5.0",
	"description": "A unified calendar events engine for Persian, Islamic, and international dates, providing bilingual event data(English & Persian), holiday classification, and a powerful query system for fixed, multi-day, and relative events.",
	"type": "module",
	"keywords": [
		"persian",
		"jalali",
		"hijri",
		"gregorian",
		"holidays",
		"events",
		"holidays",
		"iran",
		"calendar"
	],
	"license": "MIT",
	"author": {
		"name": "Alireza Mohammadzadeh(NedaMani)",
		"url": "https://nedamani.ir"
	},
	"homepage": "https://github.com/karfekr/persian-holidays",
	"bugs": {
		"url": "https://github.com/karfekr/persian-holidays/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/karfekr/persian-holidays.git"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
	"main": "./dist/cjs/index.cjs",
	"module": "./src/index.js",
	"types": "./types/index.d.ts",
	"exports": {
		".": {
			"import": "./src/index.js",
			"require": "./dist/cjs/index.cjs",
			"types": "./types/index.d.ts"
		},
		"./jalali": {
			"import": "./src/jalali.js",
			"require": "./dist/cjs/jalali.cjs",
			"types": "./types/index.d.ts"
		},
		"./gregorian": {
			"import": "./src/gregorian.js",
			"require": "./dist/cjs/gregorian.cjs",
			"types": "./types/index.d.ts"
		},
		"./hijri": {
			"import": "./src/hijri.js",
			"require": "./dist/cjs/hijri.cjs",
			"types": "./types/index.d.ts"
		}
	},
	"files": [
		"src/",
		"dist/",
		"types/",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"scripts": {
		"build:data": "node build/buildData.mjs",
		"build:cjs": "node build/buildCjs.mjs",
		"build": "node build/buildData.mjs && node build/buildCjs.mjs",
		"test": "vitest",
		"test:watch": "vitest watch",
		"test:run": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@internationalized/date": ">=3.12.0",
		"js-yaml": "^4.2.0",
		"vitest": "^4.1.8",
		"glob": "^13.0.6"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
