{
	"name": "persian-holidays",
	"version": "0.5.0",
	"description": "A unified calendar events engine for Persian, Islamic, and international dates, providing bilingual event data(English & Persian), holiday classification, and a powerful query system for fixed, multi-day, and relative events.",
	"type": "module",
	"keywords": [
		"persian",
		"jalali",
		"hijri",
		"gregorian",
		"holidays",
		"events",
		"holidays",
		"iran",
		"calendar"
	],
	"license": "MIT",
	"author": {
		"name": "Alireza Mohammadzadeh(NedaMani)",
		"url": "https://nedamani.ir"
	},
	"homepage": "https://github.com/karfekr/persian-holidays",
	"bugs": {
		"url": "https://github.com/karfekr/persian-holidays/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/karfekr/persian-holidays.git"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
	"main": "./lib/cjs/index.cjs",
	"module": "./src/index.js",
	"types": "./types/index.d.ts",
	"exports": {
		".": {
			"import": "./src/index.js",
			"require": "./lib/cjs/index.cjs",
			"types": "./types/index.d.ts"
		},
		"./jalali": {
			"import": "./src/jalali.js",
			"require": "./lib/cjs/jalali.cjs",
			"types": "./types/index.d.ts"
		},
		"./gregorian": {
			"import": "./src/gregorian.js",
			"require": "./lib/cjs/gregorian.cjs",
			"types": "./types/index.d.ts"
		},
		"./hijri": {
			"import": "./src/hijri.js",
			"require": "./lib/cjs/hijri.cjs",
			"types": "./types/index.d.ts"
		}
	},
	"files": [
		"src/",
		"lib/",
		"types/",
		"README.md",
		"README_FA.md",
		"LICENSE"
	],
	"sideEffects": false,
	"lint-staged": {
		"*.{js,cjs,mjs,ts}": [
			"eslint --fix"
		]
	},
	"scripts": {
		"build:data": "node build/buildData.mjs",
		"build:cjs": "node build/buildCjs.mjs",
		"build": "node build/buildData.mjs && node build/buildCjs.mjs",
		"test": "vitest",
		"test:watch": "vitest watch",
		"test:run": "vitest run",
		"lint": "eslint . --fix",
		"prepublishOnly": "pnpm run lint && pnpm run test && pnpm run build",
		"prepare": "husky"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": ">=3.12.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^63.0.2",
		"glob": "^13.0.6",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"js-yaml": "^4.2.0",
		"lint-staged": "^17.0.7",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
