{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"forceConsistentCasingInFileNames": true,
		"noUnusedLocals": true,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true,
		"noEmit": true
	},
	"include": [
		"src/**/*.js",
		"types/**/*.d.ts",
		"tests/**/*.js",
		"eslint.config.js"
	]
}
